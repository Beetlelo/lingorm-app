# ===== 必填：Google 登录 Client ID =====
VITE_GOOGLE_CLIENT_ID=41016440384-k1hk06mnurhnt91sb7gic0lbkvmjd2vk.apps.googleusercontent.com

# ===== 可选：七牛云存储（不配置则照片仍存浏览器本地，跨设备不共享） =====
# 空间名（Bucket）
VITE_QINIU_BUCKET=lingorm
# CDN 域名，需含 https:// 前缀（测试域名形如 https://xxx.bkt.clouddn.com，或绑定的自定义域名）
VITE_QINIU_DOMAIN=https://your-bucket.bkt.clouddn.com
# 签发上传凭证的 Cloudflare Worker 地址（见 qiniu-worker/index.js 与 QINIU_SETUP.md）
VITE_QINIU_TOKEN_URL=https://qiniu-token-your-subdomain.workers.dev
